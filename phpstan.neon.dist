includes:
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - src
        - config
        - database
    stubFiles:
        # Stub for the `gnupg` PECL extension. ext-gnupg is a composer require,
        # but phpstan can still analyze on hosts where the extension isn't loaded.
        - stubs/gnupg.stub
    tmpDir: build/phpstan
    ignoreErrors:
        # Package config files live in config/; the rule targets app-level config dirs.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/pgp-mailer.php
        # The gnupg stub declares clear{sign,encrypt,decrypt}keys() unconditionally,
        # but the PECL extension only exposes them on >= 1.3.0. The runtime
        # method_exists() guards are intentional defensive programming.
        -
            identifier: function.alreadyNarrowedType
            path: src/Engines/GnupgExtensionEngine.php
